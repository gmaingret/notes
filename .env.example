# Copy this file to .env and fill in real values before running the server.
# Never commit .env — it is in .gitignore.

# ── Google OAuth ─────────────────────────────────────────────────────────────
# From Google Cloud Console > APIs & Services > Credentials > OAuth 2.0 Client IDs
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── JWT ──────────────────────────────────────────────────────────────────────
# Random 32+ character secret. Generate with:
#   openssl rand -hex 32
JWT_SECRET=

# ── Storage paths (inside container) ─────────────────────────────────────────
DB_PATH=/data/notes.db
ATTACHMENTS_PATH=/data/files

# ── Static web build ─────────────────────────────────────────────────────────
# Path inside the container where the Flutter web build is copied at image build time
WEB_BUILD_PATH=/app/web
