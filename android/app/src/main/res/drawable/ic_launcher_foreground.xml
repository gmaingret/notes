        android:fillColor="#FFFFFF"
        android:pathData="M40,24 m-3,0 a3,3 0 1,0 6,0 a3,3 0 1,0 -6,0" />
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M54,24 m-3,0 a3,3 0 1,0 6,0 a3,3 0 1,0 -6,0" />
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M68,24 m-3,0 a3,3 0 1,0 6,0 a3,3 0 1,0 -6,0" />

    <!-- Lines representing text on the notepad -->
    <path
        android:fillColor="@android:color/transparent"
        android:strokeColor="#FFFFFF"
        android:strokeWidth="2.5"
        android:pathData="M38,42 L70,42" />
    <path
        android:fillColor="@android:color/transparent"
        android:strokeColor="#FFFFFF"
        android:strokeWidth="2.5"
        android:pathData="M38,52 L70,52" />
    <path
        android:fillColor="@android:color/transparent"
