# ===========================================
# Notes - Environment Configuration
# ===========================================
# Copy this file to .env and fill in the values.
# NEVER commit .env to the repository.

# --- Application ---
NODE_ENV=production
APP_PORT=3000
APP_URL=https://notes.gregorymaingret.fr

# --- Database ---
DB_HOST=db
DB_PORT=5432
DB_NAME=notes
DB_USER=notes
DB_PASSWORD=

# --- Authentication ---
JWT_SECRET=

# Google OAuth 2.0
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=https://notes.gregorymaingret.fr/auth/google/callback

# --- File Storage ---
UPLOAD_MAX_SIZE_MB=100
UPLOAD_PATH=/data/attachments
